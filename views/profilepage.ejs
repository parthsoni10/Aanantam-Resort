<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel</title>
    <link rel="stylesheet" href="/css/profile.css">
</head>
<body>
        <main class="content">
         
            <form id="registration-form">
                <h2>profile Form</h2>
                <label for="firstname">First Name:</label>
                <input type="text" id="firstname" value=<%= current.firstname%> required>

                <label for="lastname">Last Name:</label>
                <input type="text" id="lastname" value=<%= current.lastname%> required>

                <label for="email">Email:</label>
                <input type="email" id="email" value=<%= current.email %> required>

                <label for="contact">Contact Information:</label>
                <input type="tel" id="contact"  value=<%= current.phone %>  required>

                <label for="password">Password:</label>
                <input type="password" id="password" required>

                <label for="dob">Date of Birth:</label>
                <input type="date" id="dob"  required>

                <label for="gender">Gender:</label>
                <select id="gender" required>
                    <option value="">Select</option>
                    <option value="male">Male</option>
                    <option value="female">Female</option>
                    <option value="other">Other</option>
                </select>

                <label for="address">Address:</label>
                <input type="text" id="address"  value=<%= current.address %> required>

                <label for="state">City:</label>
                <input type="text" id="state"  value=<%= current.state %>  required>

                <label for="city">City:</label>
                <input type="text" id="city" required>

                <label for="pincode">Pincode:</label>
                <input type="text" id="pincode" required>

                <label for="hobbies">Interests and Hobbies:</label>
                <textarea id="hobbies"></textarea>

                <button type="submit">Submit</button>
            </form>
        </main>
    </div>
    <script src="/js/profile.js"></script>
</body>
</html>
