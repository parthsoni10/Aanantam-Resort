<body>

    
    <header>
        <div class="header_container">
            <a href="/home" style="text-decoration: none;">    
                <div class="header_logo">   
                    <img src="/image/logo3.jpg" style="margin:0px;" alt="Anantam">
                </div>
            </a>
    
            <nav class="header_font">
                <div><a href="/home">RESORT</a></div> 
                <div><a href="/stay/room">STAY</a></div> 
                <div><a href="/wellness/allphotos">WALLNESS</a></div> 
                <div><a href="/packages/picnic">PACKAGE</a></div> 
                <div><a href="/dining_cafeteria">DAINING</a></div> 
                <div><a href="/wedding&events_wedding">WEDDING & EVENT</a></div> 
            </nav>
    
            <div class="header_login">
                <div><a href="/bookingpage"><button id="booknow" style="font-size: 13px;" class="header_btn">BOOK NOW</button></a></div>
                <div id="user-icon" class="user-icon" style="cursor: pointer;">
                    <i class="fa-solid fa-user fa-lg" ></i>
                </div>
            </div>
                
            <!-- Dropdown Menu -->
             <% if(!current){%>
                <div id="user-dropdown" class="dropdown-menu before_login">
                        <a href="/signup"><div>Signup</div></a>
                        <a href="/login"><div>Login</div></a>
                </div>
             <% } %>
             <% if(current){%>
                <div id="user-dropdown" class="dropdown-menu">
                    <div style="margin-left: 100px;">Welcome!</div>
                    <div style="display: flex;justify-content: center;margin-top: -10px;"><h1><%= current.firstname+" "+current.lastname %></h1></div>
                    <div class="list">
                        <a href="/logout"><div>Logout</div></a>
                        <a href="/profile"><div>Profile</div></a>
                    </div>
                </div>
             <% } %>
            </div>
        </div>
    </header>

<div class="slider">
    <img id="slider-image" src="/image/r1.JPG" alt="Resort Image">
    <div class="slider-navigation">
        <button onclick="prevSlide()" style="background-color: transparent;"></button>
        <button onclick="nextSlide()" style="background-color: transparent;"  ></button>
    </div>
</div>
<!-- 
<hr>
Room Sections -->
<!-- Superior Room Section -->
<div class="room-section">
    <div class="room-image">
      <img src="/image/6.jpg" alt="Superior Room">
    </div>
    <div class="room-details">
      <h2><%= list[0].title %></h2>
      <div>
        Our Superior Rooms offer the perfect blend of comfort and elegance, designed for a relaxing stay...
      </div>
      <br>
      <table class="room-table">
        <tbody>
          <% for (let i = 0; i <= 20; i += 5) { %>
            <tr>
              <td><%= list[i].type %></td>
              <td>2 &nbsp;<i class="fa-regular fa-user"></i></td>
              <td>
                <div class="dropdown">
                  <button class="btn btn-secondary dropdown-toggle roombtn" type="button" data-bs-toggle="dropdown">
                    Select Room
                  </button>
                  <ul class="dropdown-menu">
                    <% for (let j = 0; j < 5; j++) {
                      const room = list[i + j];
                      if (!room) continue;
                    %>
                      <li>
                        <% if (room.state) { %>
                          <a class="dropdown-item room-option" href="#" data-price="<%= room.price %>" data-rooms="<%= room.room_no %>">
                            Room <%= room.room_no %>
                          </a>
                        <% } else { %>
                          <span class="dropdown-item text-muted disabled" style="pointer-events: none; opacity: 0.5;">
                            Room <%= room.room_no %> (Unavailable)
                          </span>
                        <% } %>
                      </li>
                    <% } %>
                  </ul>
                </div>
              </td>
              <td>INR <span class="room-price"><%= list[i].price %></span></td>
              <td>
                <form method="get" action="/bookingdata/<%= list[i]._id %>">
                  <input type="hidden" name="selectedRooms" value="1">
                  <input type="hidden" name="totalPrice" value="<%= list[i].price %>">
                  <button type="submit">Book Now</button>
                </form>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  
