<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/edit_admin.css">  
</head>
<body>
    <div class="admin-container">
        <nav class="sidebar">
            <h2>Admin Panel</h2>
            <ul>
                <li><a href="/admin">Dashboard</a></li>
                <li><a href="/admin/user">Users</a></li>
                <li><a href="/admin/payment">Payments</a></li>
                <li><a href="/admin/room">Rooms</a></li>
            </ul>
        </nav>
        <main class="content">
            <header>
                <h1 style="margin-left: 400px;">Edit User Information</h1> 
            </header>

               
    <div class="container">
        <form id="registrationForm" method="POST" action="/admin/edit/<%= userlist._id %>?_method=PUT">

            <label for="username" style="text-align: center;">User Name</label>
            <input type="text" id="username" name="username" style="width: 585px;"  value=<%=userlist.username%>>

            <div class="row">
                <div class="column">
  
                    <label for="contact"  style="text-align: center;"> First Name</label>
                    <input type="text" id="firstname" name="firstname" value=<%=userlist.firstname%>>

                    <label for="contact"  style="text-align: center;"> Number</label>
                    <input type="tel" id="phone" name="phone" value=<%=userlist.phone%> required>

                    <label for="address"  style="text-align: center;">Address</label>
                    <input type="text" id="address" name="address" value=<%=userlist.address%> required>
                </div>
                <div class="column">

                    <label for="contact"  style="text-align: center;"> Last Name</label>
                    <input type="text" id="lastname" name="lastname" value=<%=userlist.lastname%> required>

                    <label for="email"  style="text-align: center;">Email ID</label>
                    <input type="email" id="email" name="email" value=<%=userlist.email%> required>

                    <label for="state"  style="text-align: center;">State</label>
                    <input type="text" id="state" name="state" value=<%=userlist.state%> required>

                    
                </div>
            </div>
            <button class="add-product" style="width:130px;margin-left: 250px;">Save Change</button>
        </form>
    </div>

        </main>
    </div>
</body>
</html>