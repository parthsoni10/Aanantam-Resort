            </div>
            <div class="extra-image">
                <img src="/image/3.jpg" alt="Extra Image 1"> <!-- Replace with your image -->
            </div>
        </div>
        <div class="extra-row">
            <div class="extra-image">
                <img src="/image/3.jpg" alt="Extra Image 2"> <!-- Replace with your image -->
            </div>
            <div class="extra-content">
                <h1>Package 2</h1>
                <h3>For Kids (Rs. 1,100 Per Kid)</h3>
                <p>Lunch</br>
                    Hi-Tea</br>
                    Dinner</br>
                    Timings: 09:00 - 17:00</p>
            </div>
        </div>
        <div class="extra-row">
            <div class="extra-content">
                <h1>Package 3</h1>
                <h3>For Kids (Rs. 1,550 Per Kid)</h3>
                <p>Lunch</br>
                    Hi-Tea</br>
                    Dinner</br>
                    
