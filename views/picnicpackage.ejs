<% layout("boilerplate.ejs")  %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"/>
    <title>picnic-package Resort </title>
   
    <link rel="stylesheet" href="/css/packagespicnic.css">
</head>
<body>
    <div class="secondHeader">
        <div class="nav-container">
            <nav>
                <ul>
                    <li><a href="/packages/picnic">Picnic package</a></li>
                    <li><a href="/packages/honeymoon">Honeymoon package</a></li>
                </ul>
            </nav>
        </div>
    </div>

    
    <!-- Main Content Section -->
    <div class="content-section">
        <div class="content-row">
            <div class="content">
                <h1>Package 1</h1>
                <h3>For Adult (Rs. 1,660 Per Person)</h3>
                <p>Breakfast</br>
                    Lunch </br>
                    Hi-Tea</br>
                    Timings: 09:00 - 17:00</p>
            </div>
            <div class="image">
                <img src="/image/p2.jpg" alt="Image 1"> <!-- Replace with your image -->
            </div>
        </div>
        <div class="content-row">
            <div class="image">
                <img src="/image/p3.jpg" alt="Image 2"> <!-- Replace with your image -->
            </div>
            <div class="content">
                <h1>Package 2</h1>
                <h3>For Adult (Rs. 1,800 Per Person)</h3>
                <p> Lunch</br>
                    Hi-Tea</br>
                    Dinner</br>
                    Timings: 12:00 - 22:00</p>
            </div>
        </div>
        <div class="content-row">
            <div class="content">
                <h1>Package 3</h1>
                <h3>For Adult (Rs. 2,250 Per Person)</h3>
               <p> Lunch</br>
                    Hi-Tea</br>
                    Dinner</br>
                    Timings: 09:00 - 22:00</p>
            </div>
            <div class="image">
                <img src="/image/p4.jpg" alt="Image 3"> <!-- Replace with your image -->
            </div>
        </div>
    </div>

